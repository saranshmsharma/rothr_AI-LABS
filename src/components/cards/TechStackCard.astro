---
import stack from "@/collections/stack.json";

const { displayIds } = Astro.props;
const filtered = displayIds?.length
	? stack.filter((item) => displayIds.includes(item.id))
	: stack;

// First item (Astro) is the featured center card; rest spread out
const featured = filtered[0];
const others = filtered.slice(1);
---

<div class="stack-wrapper">
  <div class="stack-list">
    <!-- Featured: Astro, always centered on top -->
    <div class="stack-item stack-featured" style={`--index: 0; --total: ${filtered.length};`}>
      <div class="stack-card" style={`background-image: url(${featured.image})`}>
        <!-- <img src={featured.image} alt={featured.name} class="stack-img" />
        <div class="stack-text">
          <span class="stack-name">{featured.name}</span>
          <span class="stack-desc">{featured.desc}</span>
        </div> -->
      </div>
    </div>

    <!-- Others: spread left/right with slight tilt -->
    {others.map((item, index) => (
      <div
        class="stack-item stack-other"
        style={`--i: ${index + 1}; --total: ${filtered.length}; --others: ${others.length}; --half: ${Math.floor(others.length / 2)}; --spread: ${[1.0, 1.2, 1.2, 1.0][index] ?? 1};`}
      >
        <div class="stack-card" style={`background-image: url(${item.image})`}>
          {/* <img src={item.image} alt={item.name} class="stack-img" />
          <div class="stack-text">
            <span class="stack-name">{item.name}</span>
            <span class="stack-desc">{item.desc}</span>
          </div> */}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .stack-wrapper {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .stack-list {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 320px;
  }

  .stack-item {
    position: relative;
    width: 200px;
    height: 288px;
    border-radius: var(--radius-2xl);
    cursor: pointer;
    transition: transform 0.5s cubic-bezier(0.34, 1.2, 0.64, 1),
                box-shadow 0.3s ease;
  }

  /* ── Featured card (Astro) ── */
  @media (min-width: 768px) {
    .stack-featured {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      z-index: 50;
      transition-delay: 0s;
    }

    .stack-list:hover .stack-featured {
      transform: translateX(-50%) translateY(-18px) scale(1.06);
      z-index: 200;
      transition: transform 0.35s cubic-bezier(0.34, 1.5, 0.64, 1),
                  box-shadow 0.3s ease;
    }

    .stack-list:hover .stack-featured:hover {
      z-index: 99999;
    }
  }

  /* ── Other cards ── */
  @media (min-width: 768px) {
    .stack-other {
      position: absolute;
      left: 50%;
      /* Clustered: slightly offset behind featured */
      transform: translateX(-50%)
                 translateX(calc((var(--i) - var(--half) - 0.5) * 14px))
                 rotate(calc((var(--i) - var(--half) - 0.5) * 6deg));
      z-index: calc(var(--others) - var(--i) + 1);
      transition-delay: calc(var(--i) * 0.04s);
    }

    /* Spread: left/right with tilted angles */
    .stack-list:hover .stack-other {
      transform: translateX(-50%)
                 translateX(calc((var(--i) - var(--half) - 0.5) * var(--spread) * 260px))
                 rotate(calc((var(--i) - var(--half) - 0.5) * 10deg));
      z-index: calc(var(--i) + 100);
      transition-delay: calc(var(--i) * 0.04s);
    }

    .stack-list:hover .stack-other:hover {
      transform: translateX(-50%)
                 translateX(calc((var(--i) - var(--half) - 0.5) * var(--spread) * 255px))
                 translateY(-14px)
                 rotate(calc((var(--i) - var(--half) - 0.5) * 12deg))
                 scale(1.06);
      z-index: 99999;
      transition: transform 0.35s cubic-bezier(0.34, 1.5, 0.64, 1),
                  box-shadow 0.3s ease;
      transition-delay: 0s;
    }
  }

  /* Mobile: flex wrap */
  @media (max-width: 767px) {
    .stack-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      height: auto;
      justify-content: center;
    }
    .stack-item {
      position: relative;
      transform: none;
      width: 150px;
      height: 216px;
    }
    .stack-item:active {
      transform: scale(0.95);
    }
  }

  /* ── Card body ── */
  .stack-card {
    width: 100%;
    height: 100%;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    background: var(--color-bg-secondary);
    border: 1px dashed var(--color-neutral-200);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    position: relative;
    background-size: cover!important;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  :global(.dark) .stack-card {
    background: var(--color-bg-secondary-dark);
    border-color: var(--color-neutral-700);
  }

  .stack-list:hover .stack-item:hover .stack-card {
    border-color: var(--color-primary);
    border-style: solid;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12),
                0 6px 16px rgba(0, 0, 0, 0.08);
  }

  /* ── Icon ── */
  .stack-img {
    width: 56px;
    height: 56px;
    object-fit: contain;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .stack-list:hover .stack-item:hover .stack-img {
    transform: scale(1.12);
  }

  /* ── Text — bottom-right ── */
  .stack-text {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  .stack-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-neutral-800);
    line-height: 1.2;
  }

  :global(.dark) .stack-name {
    color: var(--color-neutral-200);
  }

  .stack-desc {
    font-size: 11px;
    color: var(--color-neutral-400);
    margin-top: 2px;
    line-height: 1.3;
  }

  /* ── Hover shadow ── */
  .stack-list:hover .stack-item:hover {
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.14),
                0 8px 20px rgba(0, 0, 0, 0.08);
  }
</style>
