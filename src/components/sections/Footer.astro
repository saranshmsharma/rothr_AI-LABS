---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";

const currentYear = new Date().getFullYear();

const footerLinks = {
  intelligence: [
    { name: "Preference Data", url: "/#preference-data" },
    { name: "Design Evals", url: "/#design-evals" },
    { name: "Red Teaming", url: "/#red-teaming" },
  ],
  designers: [
    { name: "Apply", url: "/contact" },
    { name: "Opportunities", url: "/contact" },
  ],
  labs: [
    { name: "For Labs", url: "/#for-labs" },
    { name: "Research", url: "/#research" },
  ],
  company: [
    { name: "Mission", url: "/mission" },
    { name: "Blog", url: "/blog" },
  ],
  legal: [
    { name: "Privacy", url: "/#privacy" },
    { name: "Terms", url: "/#terms" },
  ],
};

const templateVersion = "v1.0.0";
---

<section class="text-gray-700 border-t mt-20 md:mt-48 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]">
  <div class="container mx-auto px-7 max-w-7xl py-12 md:py-16">
    <!-- Top: Logo + Description -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-12">
      <div class="max-w-sm">
        <Logo />
        <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
          The design intelligence infrastructure for frontier AI. Mobilizing senior designers to generate high-fidelity training data.
        </p>
      </div>

      <!-- Five columns -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12">
        <!-- Intelligence -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4 font-sans">Intelligence</h4>
          <ul class="space-y-3">
            {footerLinks.intelligence.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- For Designers -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4 font-sans">For Designers</h4>
          <ul class="space-y-3">
            {footerLinks.designers.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- For Labs -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4 font-sans">For Labs</h4>
          <ul class="space-y-3">
            {footerLinks.labs.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4 font-sans">Company</h4>
          <ul class="space-y-3">
            {footerLinks.company.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4 font-sans">Legal</h4>
          <ul class="space-y-3">
            {footerLinks.legal.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-dashed border-primary/10 dark:border-primary-dark/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-400 dark:text-neutral-500">
        © {currentYear}
        <a href={siteConfig.url || " "} target="_blank" class="hover:text-primary dark:hover:text-primary-light transition-colors">{siteConfig.author || " "}</a>
      </p>

    
</section>

<!-- Back to top -->
<ToTop />

<style is:global>
  .footer-social-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .footer-social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .footer-social-icon-link:hover .ic-twitter {
    color: #1DA1F2;
  }

  .footer-social-icon-link:hover .ic-github {
    color: #333;
  }

  .footer-social-icon-link:hover .ic-rss {
    color: #F26522;
  }
</style>
