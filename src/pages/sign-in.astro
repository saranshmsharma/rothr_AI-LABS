---
import Button from "@/components/ui/Button.astro";
import Layout from "@/layouts/Layout.astro";
import { ArrowRight, CircleCheck, Lock, Mail } from "@lucide/astro";
---

<Layout
  title="Sign in — Rothr"
  description="Sign in to the Rothr workspace."
>
  <main class="site-container py-12 md:py-20">
    <section class="grid min-h-[calc(100vh-18rem)] items-center gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(420px,1.05fr)]">
      <div
        class="hidden lg:block"
        data-aos="fade-up-xs"
        data-aos-once="true"
      >
        <div class="max-w-md">
          <p class="mb-4 inline-flex rounded-full border border-primary/15 bg-primary/5 px-3 py-1 text-xs font-medium text-primary dark:border-primary-light/20 dark:bg-primary-light/10 dark:text-primary-light">
            Account access
          </p>
          <h1 class="font-brand text-5xl leading-tight tracking-normal text-neutral-800 dark:text-neutral-100">
            Welcome back to your workspace.
          </h1>
          <p class="mt-5 text-base leading-8 text-neutral-600 dark:text-neutral-300">
            A polished sign in screen for SaaS products, dashboards, and customer portals.
          </p>
        </div>

        <div class="mt-10 max-w-md border-y border-dashed border-neutral-200 py-6 dark:border-neutral-700">
          <div class="grid gap-4">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary dark:bg-primary-light/10 dark:text-primary-light">
                <CircleCheck size={16} />
              </span>
              <div>
                <h2 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">Responsive by default</h2>
                <p class="mt-1 text-sm leading-6 text-neutral-500 dark:text-neutral-400">Works as a focused single-column flow on mobile.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-accent/25 text-neutral-800 dark:bg-accent/20 dark:text-neutral-100">
                <Lock size={16} />
              </span>
              <div>
                <h2 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">Ready to connect</h2>
                <p class="mt-1 text-sm leading-6 text-neutral-500 dark:text-neutral-400">Replace the demo handler with your auth provider or API.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="mx-auto w-full max-w-md"
        data-aos="fade-up-xs"
        data-aos-once="true"
      >
        <div class="rounded-2xl border border-neutral-200 bg-bg-secondary/85 p-6 shadow-[0_18px_60px_rgba(25,34,47,0.08)] backdrop-blur dark:border-neutral-700 dark:bg-bg-secondary-dark/85 dark:shadow-[0_18px_60px_rgba(0,0,0,0.22)] sm:p-8">
          <div class="mb-8">
            <p class="text-xs font-medium uppercase tracking-[0.14em] text-primary dark:text-primary-light">Sign in</p>
            <h1 class="mt-3 font-brand text-4xl tracking-normal text-neutral-800 dark:text-neutral-100">Access your account</h1>
            <p class="mt-3 text-sm leading-6 text-neutral-500 dark:text-neutral-400">
              Use your email address or continue with a connected provider.
            </p>
          </div>

          <form id="sign-in-form" class="space-y-5">
            <div>
              <label for="email" class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-300">Email</label>
              <div class="relative">
                <Mail class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-neutral-400 dark:text-neutral-500" />
                <input
                  id="email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  required
                  placeholder="you@example.com"
                  class="w-full rounded-lg border border-neutral-200 bg-bg-secondary px-11 py-3 text-neutral-800 transition-colors placeholder:text-neutral-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 dark:border-neutral-700 dark:bg-bg-secondary-dark dark:text-neutral-100 dark:placeholder:text-neutral-500"
                />
              </div>
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between gap-4">
                <label for="password" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300">Password</label>
                <a href="javascript:void(0);" class="text-sm font-medium text-primary transition-colors hover:text-primary-strong dark:text-primary-light dark:hover:text-primary-light-dark">
                  Forgot password?
                </a>
              </div>
              <div class="relative">
                <Lock class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-neutral-400 dark:text-neutral-500" />
                <input
                  id="password"
                  name="password"
                  type="password"
                  autocomplete="current-password"
                  required
                  placeholder="Enter your password"
                  class="w-full rounded-lg border border-neutral-200 bg-bg-secondary px-11 py-3 text-neutral-800 transition-colors placeholder:text-neutral-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 dark:border-neutral-700 dark:bg-bg-secondary-dark dark:text-neutral-100 dark:placeholder:text-neutral-500"
                />
              </div>
            </div>

            <label class="flex items-center gap-3 text-sm text-neutral-600 dark:text-neutral-300">
              <input
                type="checkbox"
                name="remember"
                class="h-4 w-4 rounded border-neutral-300 text-primary focus:ring-primary/30 dark:border-neutral-600 dark:bg-bg-secondary-dark"
              />
              Remember me for 30 days
            </label>

            <div class="auth-submit">
              <Button url="javascript:void(0);" type="fill" className="w-full max-w-none justify-center">
                Sign in <ArrowRight size={16} />
              </Button>
            </div>

            <div id="sign-in-success" class="hidden rounded-lg border border-green-200 bg-green-50 p-3 text-center text-sm text-green-700 dark:border-green-800 dark:bg-green-900/20 dark:text-green-300">
              Demo sign in complete.
            </div>
          </form>

          <div class="my-6 flex items-center gap-3">
            <div class="h-px flex-1 border-t border-dashed border-neutral-200 dark:border-neutral-700"></div>
            <span class="text-xs text-neutral-400 dark:text-neutral-500">or</span>
            <div class="h-px flex-1 border-t border-dashed border-neutral-200 dark:border-neutral-700"></div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <a href="javascript:void(0);" class="inline-flex items-center justify-center gap-2 rounded-lg border border-neutral-200 bg-white px-4 py-3 text-sm font-medium text-neutral-700 transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:text-primary dark:border-neutral-700 dark:bg-neutral-900/30 dark:text-neutral-200 dark:hover:text-primary-light">
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49v-1.74c-2.78.62-3.37-1.38-3.37-1.38-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.96c.85 0 1.7.12 2.5.35 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.07.36.32.68.94.68 1.9v2.81c0 .27.18.59.69.49A10.19 10.19 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" />
              </svg>
              GitHub
            </a>
            <a href="javascript:void(0);" class="inline-flex items-center justify-center gap-2 rounded-lg border border-neutral-200 bg-white px-4 py-3 text-sm font-medium text-neutral-700 transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:text-primary dark:border-neutral-700 dark:bg-neutral-900/30 dark:text-neutral-200 dark:hover:text-primary-light">
              <span class="flex h-4 w-4 items-center justify-center rounded-full border border-current text-[10px] font-semibold leading-none">G</span>
              Google
            </a>
          </div>

          <p class="mt-8 text-center text-sm text-neutral-500 dark:text-neutral-400">
            New to RicoFast?
            <a href="/sign-up" class="font-medium text-primary transition-colors hover:text-primary-strong dark:text-primary-light dark:hover:text-primary-light-dark">Create an account</a>
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById('sign-in-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('sign-in-success');
  const submitBtn = form?.querySelector('.auth-submit a') as HTMLAnchorElement | null;

  submitBtn?.addEventListener('click', (event) => {
    event.preventDefault();

    if (!form?.checkValidity()) {
      form?.reportValidity();
      return;
    }

    successMsg?.classList.remove('hidden');
    form.reset();
  });
</script>
