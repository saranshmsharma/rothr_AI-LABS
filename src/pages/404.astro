---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import PageLayout from "@/layouts/PageLayout.astro";
import {
	ArrowLeft,
	Compass,
	House,
	Mail,
	Search,
	ShieldAlert,
} from "@lucide/astro";
---

<PageLayout title="Page Not Found — Rothr" description="The page you're looking for doesn't exist." robots="noindex, nofollow">
  <section class="site-container py-14 md:py-24">
    <div class="grid min-h-[62vh] items-center gap-10 lg:grid-cols-[minmax(0,0.92fr)_minmax(420px,1fr)]">
      <div data-aos="fade-up-xs" data-aos-once="true">
        <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-xs font-medium text-primary dark:border-primary-light/20 dark:bg-primary-light/10 dark:text-primary-light">
          <ShieldAlert size={14} />
          Error 404
        </p>

        <h1 class="max-w-2xl font-brand text-5xl leading-[1.04] tracking-normal text-neutral-800 dark:text-neutral-100 md:text-6xl">
          This route does not have a page yet.
        </h1>

        <p class="mt-5 max-w-xl text-base leading-8 text-neutral-600 dark:text-neutral-300">
          The link may be outdated, mistyped, or still waiting to be built. Start from a known page, or send us the broken URL so we can trace it.
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <Button url="/" type="fill">
            <ArrowLeft size={16} /> Back to Home
          </Button>
          <Button url={`mailto:${siteConfig.mail}?subject=Broken%20link%20on%20Rothr`}>
            <Mail size={16} /> Report link
          </Button>
        </div>

      </div>

      <div
        class="relative mx-auto w-full max-w-lg"
        data-aos="fade-up-xs"
        data-aos-delay="120"
        data-aos-once="true"
      >
        <div class="relative overflow-hidden rounded-2xl border border-neutral-200 bg-bg-secondary/80 p-5 shadow-[0_22px_70px_rgba(25,34,47,0.09)] backdrop-blur dark:border-neutral-700 dark:bg-bg-secondary-dark/80 dark:shadow-[0_22px_70px_rgba(0,0,0,0.24)] sm:p-6">
          <div class="absolute inset-0 opacity-[0.08] dark:opacity-[0.12]">
            <div class="h-full w-full bg-[linear-gradient(to_right,currentColor_1px,transparent_1px),linear-gradient(to_bottom,currentColor_1px,transparent_1px)] bg-[size:28px_28px] text-primary"></div>
          </div>

          <div class="relative">
            <div class="mb-5 flex items-center justify-between gap-4 border-b border-dashed border-neutral-200 pb-4 dark:border-neutral-700">
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-red-400"></span>
                <span class="h-3 w-3 rounded-full bg-accent"></span>
                <span class="h-3 w-3 rounded-full bg-primary"></span>
              </div>
              <span class="text-xs font-medium text-neutral-400 dark:text-neutral-500">route scan</span>
            </div>

            <div class="rounded-xl border border-dashed border-primary/25 bg-bg-primary/60 p-4 dark:border-primary-light/20 dark:bg-bg-primary-dark/60">
              <div class="flex items-center gap-3">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary text-white">
                  <Search size={19} />
                </div>
                <div class="min-w-0">
                  <p class="text-xs font-medium uppercase tracking-[0.14em] text-neutral-400 dark:text-neutral-500">Requested path</p>
                  <p id="missing-path" class="mt-1 truncate text-sm font-medium text-neutral-800 dark:text-neutral-100">/unknown-route</p>
                </div>
              </div>
            </div>

            <div class="my-8 flex items-center justify-center">
              <div class="relative h-32 w-full max-w-sm">
                <div class="absolute left-4 top-1/2 h-px w-[calc(100%-2rem)] border-t border-dashed border-neutral-300 dark:border-neutral-600"></div>
                <div class="absolute left-0 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-xl border border-primary/20 bg-white text-primary shadow-sm dark:border-primary-light/25 dark:bg-neutral-900 dark:text-primary-light">
                  <House size={18} />
                </div>
                <div class="absolute left-1/2 top-1/2 flex h-16 w-16 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-2xl border border-dashed border-red-300 bg-red-50 text-red-500 dark:border-red-900/70 dark:bg-red-950/25 dark:text-red-300">
                  <span class="font-brand text-3xl leading-none">404</span>
                </div>
                <div class="absolute right-0 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-xl border border-primary/20 bg-white text-primary shadow-sm dark:border-primary-light/25 dark:bg-neutral-900 dark:text-primary-light">
                  <Compass size={18} />
                </div>
              </div>
            </div>

            <div class="grid gap-3 text-sm">
              <div class="flex items-center justify-between rounded-lg border border-neutral-200 bg-white/70 px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900/40">
                <span class="text-neutral-500 dark:text-neutral-400">DNS</span>
                <span class="font-medium text-green-600 dark:text-green-300">reachable</span>
              </div>
              <div class="flex items-center justify-between rounded-lg border border-neutral-200 bg-white/70 px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900/40">
                <span class="text-neutral-500 dark:text-neutral-400">Page route</span>
                <span class="font-medium text-red-500 dark:text-red-300">missing</span>
              </div>
              <div class="flex items-center justify-between rounded-lg border border-neutral-200 bg-white/70 px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900/40">
                <span class="text-neutral-500 dark:text-neutral-400">Next step</span>
                <span class="font-medium text-primary dark:text-primary-light">choose a known path</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const missingPath = document.getElementById('missing-path');
  if (missingPath) {
    missingPath.textContent = window.location.pathname;
  }
</script>
