---
import PageHeader from "@/components/elements/PageHeader.astro";
import SectionHeader from "@/components/elements/SectionHeader.astro";
import AccordionItem from "@/components/ui/AccordionItem.astro";
import AnimatedText from "@/components/ui/AnimatedText.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import PricingToggle from "@/components/ui/PricingToggle.astro";
import Layout from "@/layouts/Layout.astro";
import {
	ArrowRight,
	Bot,
	ChartNoAxesColumn,
	Check,
	ChevronDown,
	ChevronLeft,
	ChevronRight,
	CircleAlert,
	CircleCheck,
	Code,
	Copy,
	Download,
	ExternalLink,
	FileText,
	GitFork,
	Globe,
	Grid3x3,
	Info,
	Layers,
	LayoutDashboard,
	List,
	Lock,
	Mail,
	Menu,
	Monitor,
	Moon,
	Palette,
	PenTool,
	Rocket,
	Rss,
	Search,
	Shield,
	Smartphone,
	Sparkles,
	Sun,
	TriangleAlert,
	Wrench,
	X,
	Zap,
} from "@lucide/astro";

const colorPalette = [
	{ name: "Primary Blue", value: "#2d6dc3", token: "--color-primary" },
	{ name: "Primary Strong", value: "#0066ff", token: "--color-primary-strong" },
	{ name: "Primary Light", value: "#8fb9ff", token: "--color-primary-light" },
	{ name: "Accent Gold", value: "#fad13b", token: "--color-accent" },
];

const neutralScale = [
	{ name: "50", value: "#f7f9fc" },
	{ name: "100", value: "#edf1f8" },
	{ name: "200", value: "#dfe4ed" },
	{ name: "300", value: "#c5cedb" },
	{ name: "400", value: "#92a1b7" },
	{ name: "500", value: "#677487" },
	{ name: "600", value: "#4f5a6d" },
	{ name: "700", value: "#3f4a5a" },
	{ name: "800", value: "#2c3542" },
	{ name: "900", value: "#19222f" },
	{ name: "950", value: "#10161f" },
];

const bgColors = [
	{ name: "BG Primary", value: "#fdfaf5", token: "--color-bg-primary" },
	{ name: "BG Secondary", value: "#ffffff", token: "--color-bg-secondary" },
	{
		name: "BG Primary Light",
		value: "#faf9f5",
		token: "--color-bg-primary-light",
	},
	{
		name: "BG Primary Dark",
		value: "#0b1220",
		token: "--color-bg-primary-dark",
	},
	{
		name: "BG Secondary Dark",
		value: "#0f1b2d",
		token: "--color-bg-secondary-dark",
	},
];

const textColors = [
	{ name: "Text Primary", value: "#2d6dc3", token: "--color-text-primary" },
	{ name: "Text Secondary", value: "#3f4a5a", token: "--color-text-secondary" },
	{ name: "Text Tertiary", value: "#7a6550", token: "--color-text-tertiary" },
];

const icons = [
	{ Icon: Menu, name: "Menu", usage: "Mobile nav" },
	{ Icon: X, name: "X", usage: "Close" },
	{ Icon: ChevronRight, name: "ChevronRight", usage: "Breadcrumbs" },
	{ Icon: ChevronLeft, name: "ChevronLeft", usage: "Pagination" },
	{ Icon: ChevronDown, name: "ChevronDown", usage: "Dropdowns" },
	{ Icon: ArrowRight, name: "ArrowRight", usage: "CTA buttons" },
	{ Icon: ExternalLink, name: "ExternalLink", usage: "External links" },
	{ Icon: Sun, name: "Sun", usage: "Light mode" },
	{ Icon: Moon, name: "Moon", usage: "Dark mode" },
	{ Icon: Mail, name: "Mail", usage: "Contact" },
	{ Icon: Search, name: "Search", usage: "Search" },
	{ Icon: Download, name: "Download", usage: "Downloads" },
	{ Icon: Copy, name: "Copy", usage: "Copy text" },
	{ Icon: Check, name: "Check", usage: "Confirm" },
	{ Icon: FileText, name: "FileText", usage: "Blog/Docs" },
	{ Icon: LayoutDashboard, name: "Layout", usage: "Page layout" },
	{ Icon: Layers, name: "Layers", usage: "Sections" },
	{ Icon: Grid3x3, name: "Grid", usage: "Grid view" },
	{ Icon: List, name: "List", usage: "List view" },
	{ Icon: GitFork, name: "GitFork", usage: "GitHub link" },
	{ Icon: Rss, name: "Rss", usage: "RSS feed" },
	{ Icon: Zap, name: "Zap", usage: "Performance" },
	{ Icon: Sparkles, name: "Sparkles", usage: "Animations" },
	{ Icon: Palette, name: "Palette", usage: "Customize" },
	{ Icon: Code, name: "Code", usage: "Development" },
	{ Icon: Globe, name: "Globe", usage: "Web" },
	{ Icon: Shield, name: "Shield", usage: "Security" },
	{ Icon: Lock, name: "Lock", usage: "Auth" },
	{ Icon: Rocket, name: "Rocket", usage: "Launch" },
	{ Icon: Bot, name: "Bot", usage: "AI tools" },
	{ Icon: ChartNoAxesColumn, name: "BarChart", usage: "Analytics" },
	{ Icon: PenTool, name: "PenTool", usage: "Design" },
	{ Icon: Monitor, name: "Monitor", usage: "Desktop" },
	{ Icon: Smartphone, name: "Smartphone", usage: "Mobile" },
	{ Icon: CircleAlert, name: "AlertCircle", usage: "Error state" },
	{ Icon: CircleCheck, name: "CheckCircle", usage: "Success" },
	{ Icon: Info, name: "Info", usage: "Information" },
	{ Icon: TriangleAlert, name: "AlertTriangle", usage: "Warning" },
	{ Icon: Wrench, name: "Wrench", usage: "Settings" },
];

const sampleFaq = [
	{
		question: "Sample accordion question?",
		answer:
			"This is a sample answer to demonstrate the AccordionItem component. It supports rich HTML content.",
	},
	{
		question: "Can I customize this?",
		answer:
			"Yes, all components accept props for easy customization. Check the source code for available options.",
	},
];
---

<Layout
  title="Elements — Rothr"
  description="Component library and design system reference for the Rothr website."
>
  <section class="site-container my-12">
    <PageHeader
      title="Elements"
      description="Component library and design system reference for Rothr."
    />
  </section>

  <!-- 1. Colors -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Colors</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Primary palette, neutral scale, backgrounds, and text colors.</p>

    <div class="space-y-10">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Primary Palette</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {colorPalette.map((c) => (
            <div class="rounded-xl overflow-hidden border border-neutral-200 dark:border-neutral-700">
              <div class="h-20" style={`background-color: ${c.value}`}></div>
              <div class="p-3">
                <p class="text-xs font-semibold text-neutral-800 dark:text-neutral-100">{c.name}</p>
                <p class="text-xs text-neutral-400 font-mono mt-0.5">{c.value}</p>
                <p class="text-xs text-neutral-400 font-mono">{c.token}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Neutral Scale</h3>
        <div class="grid grid-cols-3 sm:grid-cols-6 lg:grid-cols-11 gap-2">
          {neutralScale.map((c) => (
            <div class="text-center">
              <div class="h-14 rounded-lg border border-neutral-200 dark:border-neutral-700" style={`background-color: ${c.value}`}></div>
              <p class="text-[10px] text-neutral-500 mt-1">{c.name}</p>
              <p class="text-[10px] text-neutral-400 font-mono">{c.value}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Background Colors</h3>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
          {bgColors.map((c) => (
            <div class="text-center">
              <div class="h-16 rounded-lg border border-neutral-200 dark:border-neutral-700" style={`background-color: ${c.value}`}></div>
              <p class="text-xs text-neutral-500 mt-2">{c.name}</p>
              <p class="text-[10px] text-neutral-400 font-mono">{c.value}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Text Colors</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {textColors.map((c) => (
            <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
              <div class="w-8 h-8 rounded-lg mb-2" style={`background-color: ${c.value}`}></div>
              <p class="text-sm font-medium" style={`color: ${c.value}`}>{c.name}</p>
              <p class="text-xs text-neutral-400 font-mono">{c.value}</p>
              <p class="text-xs text-neutral-400 font-mono">{c.token}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 2. Typography -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Typography</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Font families, type scale, and weight variants.</p>

    <div class="space-y-10">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Font Families</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-2 font-mono">--font-brand (Instrument Serif)</p>
            <p class="text-3xl font-brand text-neutral-800 dark:text-neutral-100">Launch a polished SaaS</p>
          </div>
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-2 font-mono">--font-sans (Inter)</p>
            <p class="text-3xl font-sans text-neutral-800 dark:text-neutral-100">Clean body text</p>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Type Scale</h3>
        <div class="space-y-4">
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Display — 48px / 400</p>
            <p class="text-5xl font-brand text-neutral-800 dark:text-neutral-100">Display headline</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Heading 1 — 36px / 400</p>
            <p class="text-4xl font-brand text-neutral-800 dark:text-neutral-100">Main heading</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Heading 2 — 28px / 400</p>
            <p class="text-3xl font-brand text-neutral-800 dark:text-neutral-100">Section heading</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Heading 3 — 20px / 600</p>
            <p class="text-xl font-semibold text-neutral-800 dark:text-neutral-100">Subsection heading</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Body — 16px / 400</p>
            <p class="text-base text-neutral-600 dark:text-neutral-300 leading-relaxed">The quick brown fox jumps over the lazy dog. A clean, fast, and reusable SaaS template built with Astro and Tailwind CSS.</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Body Small — 14px / 400</p>
            <p class="text-sm text-neutral-500 dark:text-neutral-400">Supporting text for descriptions and secondary content.</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Caption — 12px / 400</p>
            <p class="text-xs text-neutral-400">Timestamps, metadata, and fine print.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 3. Buttons -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Buttons</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Primary, secondary, outline, and disabled variants in multiple sizes.</p>

    <div class="space-y-8">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Variants</h3>
        <div class="flex flex-wrap items-center gap-4">
          <Button url="#" type="fill">Primary filled</Button>
          <Button url="#" type="solid">Secondary solid</Button>
          <Button url="#" type="outline">Outline</Button>
          <Button url="#" type="disabled">Disabled</Button>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Sizes</h3>
        <div class="flex flex-wrap items-center gap-4">
          <Button url="#" type="fill" size="xs">Extra Small</Button>
          <Button url="#" type="fill" size="sm">Small</Button>
          <Button url="#" type="fill" size="md">Medium</Button>
          <Button url="#" type="fill" size="lg">Large</Button>
          <Button url="#" type="fill" size="xl">Extra Large</Button>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">With Icons</h3>
        <div class="flex flex-wrap items-center gap-4">
          <Button url="#" type="fill">Get Started <ArrowRight size={16} /></Button>
          <Button url="#" type="outline"><Mail size={16} /> Send Email</Button>
          <Button url="#" type="fill"><GitFork size={16} /> Star on GitHub</Button>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 4. Badges -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Badges & Tags</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Status labels and tags in multiple variants and sizes.</p>

    <div class="space-y-8">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Variants</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Badge variant="primary">Primary</Badge>
          <Badge variant="accent">Accent</Badge>
          <Badge variant="neutral">Neutral</Badge>
          <Badge variant="success">Success</Badge>
          <Badge variant="warning">Warning</Badge>
          <Badge variant="error">Error</Badge>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Sizes</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Badge variant="primary" size="sm">Small</Badge>
          <Badge variant="primary" size="default">Default</Badge>
          <Badge variant="primary" size="lg">Large</Badge>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 5. Cards -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Cards</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Basic, feature, and content card styles.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700">
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-2">Basic Card</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">A simple card with border, background, and padding.</p>
      </div>

      <div class="p-6 rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
          <Zap class="w-5 h-5 text-primary" />
        </div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-2">Feature Card</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">With icon, hover lift effect, and shadow.</p>
      </div>

      <div class="rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 overflow-hidden">
        <div class="h-32 bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center">
          <Sparkles class="w-8 h-8 text-primary/50" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-2">Content Card</h3>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">With image placeholder, like blog cards.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 6. Form Elements -->
  <section class="site-container py-16 md:py-24 max-w-2xl mx-auto" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Form Elements</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Inputs, selects, textareas, and toggle switches.</p>

    <div class="space-y-6">
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Text Input</label>
        <input type="text" placeholder="Enter your name" class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Email Input</label>
        <input type="email" placeholder="your@email.com" class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Select</label>
        <select class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors">
          <option>Option A</option>
          <option>Option B</option>
          <option>Option C</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Textarea</label>
        <textarea rows="3" placeholder="Write your message..." class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-none"></textarea>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Toggle Switch</h3>
        <PricingToggle />
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 7. Layout Elements -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Layout Elements</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Section headers, page headers, and separators.</p>

    <div class="space-y-8">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Section Header</h3>
        <SectionHeader title="Section title goes here" description="Optional description text for additional context." />
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Separator Variants</h3>
        <div class="space-y-4">
          <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>
          <div class="w-full border-b border-dashed border-primary/10 dark:border-primary-dark/10"></div>
          <div class="w-full border-b border-neutral-200 dark:border-neutral-700"></div>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Container Widths</h3>
        <div class="space-y-4">
          <div class="p-4 bg-primary/5 rounded-lg border border-dashed border-primary/20">
            <p class="text-xs text-primary">site-container (max-width: 1200px)</p>
          </div>
          <div class="max-w-2xl mx-auto p-4 bg-primary/5 rounded-lg border border-dashed border-primary/20">
            <p class="text-xs text-primary">Inner content (max-width: 672px)</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 8. Motion -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Motion & Animation</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Scroll animations, hover effects, and transition demos.</p>

    <div class="space-y-10">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-6">AOS Scroll Animations</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700 text-center" data-aos="fade-up-sm" data-aos-once="true">
            <p class="text-sm font-medium text-neutral-800 dark:text-neutral-100">fade-up-sm</p>
          </div>
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700 text-center" data-aos="fade-left-sm" data-aos-delay="100" data-aos-once="true">
            <p class="text-sm font-medium text-neutral-800 dark:text-neutral-100">fade-left-sm</p>
          </div>
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700 text-center" data-aos="fade-up-xs" data-aos-delay="200" data-aos-once="true">
            <p class="text-sm font-medium text-neutral-800 dark:text-neutral-100">fade-up-xs</p>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">AnimatedText</h3>
        <div class="p-8 rounded-xl border border-neutral-200 dark:border-neutral-700">
          <AnimatedText content="Staggered word animation demo" delay={0.5} stagger={0.08} />
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Hover Effects</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-pointer">
            <p class="text-sm font-medium text-neutral-800 dark:text-neutral-100">Card Lift</p>
            <p class="text-xs text-neutral-400 mt-1">translateY + shadow</p>
          </div>
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700 text-center transition-all duration-200 hover:shadow-[0_0_20px_rgba(45,109,195,0.15)] cursor-pointer">
            <p class="text-sm font-medium text-neutral-800 dark:text-neutral-100">Button Glow</p>
            <p class="text-xs text-neutral-400 mt-1">Primary glow shadow</p>
          </div>
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700 text-center">
            <a href="#" class="text-sm font-medium text-primary hover:underline underline-offset-4 transition-all">Link underline</a>
            <p class="text-xs text-neutral-400 mt-2">Underline animation</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 9. Accordion -->
  <section class="site-container py-16 md:py-24 max-w-2xl mx-auto" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Accordion / FAQ</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-8">Collapsible content panels.</p>

    {sampleFaq.map((item, i) => (
      <AccordionItem question={item.question} answer={item.answer} index={i} />
    ))}
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 10. Icons -->
  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">Icons</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">Lucide icon set used throughout the template.</p>

    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
      {icons.map(({ Icon, name, usage }) => (
        <div class="flex flex-col items-center p-3 rounded-xl border border-neutral-200 dark:border-neutral-700 hover:border-primary/30 transition-colors">
          <Icon class="w-5 h-5 text-neutral-600 dark:text-neutral-300 mb-2" />
          <span class="text-[10px] font-medium text-neutral-700 dark:text-neutral-200 text-center">{name}</span>
          <span class="text-[9px] text-neutral-400 text-center">{usage}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
