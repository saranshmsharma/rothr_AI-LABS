---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import {
	ArrowRight,
	ArrowUpRight,
	Award,
	Briefcase,
	Check,
	Clock,
	Database,
	DollarSign,
	Eye,
	EyeOff,
	Landmark,
	Layers,
	PenTool,
	Search,
	Shield,
	Sparkles,
	Target,
	TrendingUp,
	Globe as U,
	Users,
	Zap,
} from "@lucide/astro";

// Stats bar data
const statsBar = [
	{ value: "500+", label: "Vetted design experts" },
	{ value: "6", label: "Design domains" },
	{ value: "48hr", label: "Expert deployment" },
	{ value: "$75", label: "Avg. hourly rate" },
];

// Product Pillars data
const productPillars = [
	{
		id: "preference-data",
		icon: Database,
		title: "Preference Data",
		desc: "Senior designers rank and explain AI-generated UI outputs to generate RLHF training pairs grounded in real design reasoning.",
	},
	{
		id: "design-evals",
		icon: Eye,
		title: "Design Evals",
		desc: "Structured evaluation environments where expert designers assess model outputs against accessibility, hierarchy, interaction, and craft standards.",
	},
	{
		id: "red-teaming",
		icon: Shield,
		title: "Red Teaming",
		desc: "Designers surface failure modes in AI design tools and agents — with the vocabulary to document why the output fails and how to fix it.",
	},
];

// Problem Cards
const labsProblems = [
	{
		icon: Target,
		title: "Wrong domain, wrong signal",
		desc: "General annotators describe what they see. Senior designers explain why it fails. The difference is the training signal your model actually needs.",
	},
	{
		icon: Search,
		title: "No design-specific vetting exists",
		desc: "Current platforms can't distinguish a 6-year enterprise UX designer from someone who completed an online course last month. You're getting noise.",
	},
	{
		icon: Clock,
		title: "Months to source, days to lose",
		desc: "By the time you've sourced, vetted, and onboarded design talent through generalist platforms, your training window has closed.",
	},
];

const designersProblems = [
	{
		icon: EyeOff,
		title: "You're invisible to the AI training economy",
		desc: "RLHF platforms weren't built for designers. Your domain doesn't map to their categories. Your expertise isn't captured.",
	},
	{
		icon: DollarSign,
		title: "Expert judgment, annotator rates",
		desc: "Platforms that do accept designers pay crowd wages. Six years of UX reasoning is worth more than the market currently offers.",
	},
	{
		icon: Layers,
		title: "No infrastructure built for you",
		desc: "There's no vetted path from senior designer to AI training contributor. The demand exists. The on-ramp doesn't — until now.",
	},
];

// How It Works
const labsSteps = [
	{
		num: "01",
		title: "Tell us what you need",
		desc: "Share your task type, design domain, volume, and timeline. Self-service or through our team.",
	},
	{
		num: "02",
		title: "Get a vetted shortlist in 48 hours",
		desc: "We match and surface verified design experts against your specific requirements. No sourcing on your end.",
	},
	{
		num: "03",
		title: "Deploy into your environment",
		desc: "Experts work inside your annotation tools or Rothr's structured task workspace. No migrations, no lock-in.",
	},
	{
		num: "04",
		title: "Scale with confidence",
		desc: "Start with a 5-person pilot. Scale to production teams of 50+ with the same vetting quality and structured output format.",
	},
];

const designersSteps = [
	{
		num: "01",
		title: "Apply in 10 minutes",
		desc: "Tell us your domain, seniority, and what kinds of tasks you want. No portfolio required.",
	},
	{
		num: "02",
		title: "Complete a reasoning assessment",
		desc: "We evaluate design judgment, not aesthetics. One test. No tricks.",
	},
	{
		num: "03",
		title: "Get matched to tasks",
		desc: "Rothr surfaces relevant work from labs that fit your background and schedule. You decide what to accept.",
	},
	{
		num: "04",
		title: "Get paid",
		desc: "Get paid $40–120/hr for async sessions of 30–90 minutes. Milestone-based. Transparent before you start.",
	},
];

// Task Types
const taskTypes = [
	{
    id: "preference-ranking",
		title: "Preference Ranking",
		desc: "Compare two AI-generated UI variants. Choose the stronger one and explain your reasoning in design terms.",
	},
	{
    id: "ui-annotation",
		title: "UI Annotation",
		desc: "Mark specific failures in hierarchy, visual weight, accessibility, and interaction clarity on wireframes or mocks.",
	},
	{
    id: "rationale-writing",
		title: "Rationale Writing",
		desc: "Write structured design rationale that helps models learn what good looks like — and why.",
	},
	{
    id: "red-teaming",
		title: "Red Teaming",
		desc: "Push AI design tools to their failure modes. Document what breaks, how it breaks, and what the right output should be.",
	},
];

// Domains
const domains = [
	{ name: "Enterprise / B2B UX", icon: Landmark },
	{ name: "Consumer Product Design", icon: Users },
	{ name: "Design Systems & Tokens", icon: Layers },
	{ name: "Accessibility & Inclusive Design", icon: Award },
	{ name: "Fintech & Complex Data Workflows", icon: Database },
	{ name: "AI-native Product Interfaces", icon: Zap },
];

// Stats Credibility Section
const credibilityStats = [
	{ value: "500+", label: "Vetted design experts across 6 domains" },
	{ value: "48hr", label: "From project post to expert shortlist" },
	{ value: "$40–120/hr", label: "Expert earnings per session" },
	{ value: "10 min", label: "Designer application time" },
	{ value: "5→50+", label: "Pilot to production scaling" },
	{ value: "0", label: "Platforms you need to replace" },
];
---

<Layout
  title="Rothr — Design intelligence for frontier AI"
  description="Rothr mobilizes senior product designers to generate high-quality preference data, UI evaluations, and design rationale that teaches frontier models what good actually looks like."
  keywords="design intelligence, AI preference data, UI evaluation, red teaming, reinforcement learning, human feedback, RLHF"
>

  <!-- 1. HERO SECTION -->
  <section class="relative pt-20 pb-16 md:pt-28 md:pb-24 lg:pt-36 lg:pb-32 site-container overflow-hidden">
    <!-- Ambient decorative light bursts -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/5 dark:bg-primary/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>
    
    <div class="max-w-4xl mx-auto text-center flex flex-col items-center">
      <!-- Eyebrow badge -->
      <div
        class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-primary/20 bg-primary/5 dark:border-primary-light/10 dark:bg-primary-light/5 text-xs font-semibold uppercase tracking-wider text-primary dark:text-primary-light mb-6"
        data-aos="fade-up"
        data-aos-once="true"
      >
        <Sparkles size={12} class="animate-pulse" />
        <span>Design intelligence for frontier AI</span>
      </div>

      <!-- Headline -->
      <h1 
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-brand text-neutral-800 dark:text-neutral-100 font-normal leading-[1.1] tracking-tight mb-6"
        data-aos="fade-up"
        data-aos-delay="100"
        data-aos-once="true"
      >
        The expert layer between AI labs and great design.
      </h1>

      <!-- Subtext -->
      <p 
        class="text-base sm:text-lg md:text-xl text-neutral-600 dark:text-neutral-300 leading-relaxed max-w-3xl mb-10"
        data-aos="fade-up"
        data-aos-delay="200"
        data-aos-once="true"
      >
        Rothr mobilizes senior product designers to generate high-quality preference data, UI evaluations, and design rationale that teaches frontier models what good actually looks like.
      </p>

      <!-- CTAs -->
      <div 
        class="flex flex-wrap justify-center gap-4 mb-16"
        data-aos="fade-up"
        data-aos-delay="300"
        data-aos-once="true"
      >
        <Button url={siteConfig.cta.partnerForm} type="fill" className="text-base px-8 py-3.5 flex items-center gap-2">
          Partner with us <ArrowRight size={16} />
        </Button>
        <Button url={siteConfig.cta.expertRegister} type="outline" className="text-base px-8 py-3.5">
          Join as an expert
        </Button>
      </div>

      <!-- Stats bar -->
      <div 
        class="w-full max-w-3xl grid grid-cols-2 md:grid-cols-4 gap-6 p-6 rounded-2xl bg-bg-secondary/60 dark:bg-bg-secondary-dark/60 border border-primary/10 dark:border-neutral-800 backdrop-blur-md"
        data-aos="fade-up"
        data-aos-delay="400"
        data-aos-once="true"
      >
        {statsBar.map((stat) => (
          <div class="text-center">
            <span class="block text-2xl md:text-3xl font-bold font-sans text-neutral-800 dark:text-neutral-100">{stat.value}</span>
            <span class="block text-xs text-neutral-500 dark:text-neutral-400 mt-1 font-medium">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GLOBE VISUAL SECTION WITH OVERLAYS -->
  <section class="relative py-12 site-container overflow-hidden border-t border-dashed border-primary/10 dark:border-neutral-850">
    <!-- Globe background wireframe vector -->
    <svg viewBox="0 0 800 400" class="absolute top-[40%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-[850px] h-[450px] opacity-15 dark:opacity-25 pointer-events-none -z-10 text-primary-light">
      <defs>
        <radialGradient id="globe-glow" cx="50%" cy="100%" r="50%">
          <stop offset="0%" stop-color="var(--color-primary)" stop-opacity="0.35" />
          <stop offset="100%" stop-color="var(--color-bg-primary)" stop-opacity="0" />
        </radialGradient>
      </defs>
      <!-- Globe glow base -->
      <ellipse cx="400" cy="400" rx="320" ry="320" fill="url(#globe-glow)" />
      <!-- Dotted grid circles -->
      <ellipse cx="400" cy="400" rx="280" ry="280" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      <ellipse cx="400" cy="400" rx="240" ry="240" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      <ellipse cx="400" cy="400" rx="200" ry="200" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      <ellipse cx="400" cy="400" rx="160" ry="160" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      <ellipse cx="400" cy="400" rx="120" ry="120" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      
      <!-- Longitude arcs -->
      <path d="M 120 400 A 280 280 0 0 1 680 400" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      <path d="M 120 400 A 280 200 0 0 1 680 400" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      <path d="M 120 400 A 280 120 0 0 1 680 400" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      <path d="M 120 400 A 280 40 0 0 1 680 400" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
<path d="M 120 400 A 280 20 0 0 1 680 400" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
<path d="M 120 400 A 280 60 0 0 1 680 400" fill="none" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
      
      <!-- vertical center lines -->
      <line x1="400" y1="120" x2="400" y2="400" stroke="currentColor" stroke-dasharray="4 8" stroke-width="1" />
    </svg>

    <div aria-hidden="true" role="presentation" class="relative h-[320px] w-full select-none overflow-y-clip sm:h-[360px] lg:h-115">
