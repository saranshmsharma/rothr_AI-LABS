  <style>
    /* ─── Globe Section radial meteors animation ───────── */
    .animate-meteor-outward {
      animation: meteor-outward linear infinite;
    }
    @keyframes meteor-outward {
      0% {
        transform: rotate(var(--angle)) translate(0, 0) scale(0.5);
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        transform: rotate(var(--angle)) translate(320px, 0) scale(1.1);
        opacity: 0;
      }
    }

    /* ─── Job Feed Loop scrolling animation ─────────── */
    .animate-job-scroll {
      animation: jobFeedScroll 24s linear infinite;
    }
    @keyframes jobFeedScroll {
      0% {
        transform: translateY(0);
      }
      100% {
        transform: translateY(-50%);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .animate-meteor-outward,
      .animate-job-scroll {
        animation: none !important;
      }
    }
  </style>

