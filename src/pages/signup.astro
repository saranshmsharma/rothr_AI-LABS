---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import {
	ArrowRight,
	Check,
	Eye,
	EyeOff,
	GitFork,
	Lock,
	Mail,
	User,
} from "@lucide/astro";
---

<Layout
  title="Sign up — Rothr"
  description="Create your Rothr account in seconds."
>
  <section class="site-container py-12 md:py-20 flex items-center justify-center min-h-[calc(100vh-8rem)]">
    <div class="w-full max-w-md" data-aos="fade-up-xs" data-aos-once="true">
      <!-- Card -->
      <div class="relative p-7 md:p-9 rounded-2xl bg-bg-secondary dark:bg-bg-secondary-dark border border-dashed border-primary/20 dark:border-neutral-700">
        <!-- Brand mark -->
        <div class="flex flex-col items-center text-center mb-7">
          <a href="/" class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-bg-primary dark:bg-bg-primary-dark border border-dashed border-primary/30 dark:border-neutral-700 mb-4">
            <img src="/assets/logo.png" alt={siteConfig.title} width="32" height="32" class="w-8 h-8 rounded-full" />
          </a>
          <h1 class="text-3xl md:text-4xl font-brand text-neutral-800 dark:text-neutral-100 mb-1.5">Create your account</h1>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">Start shipping with {siteConfig.title} in minutes</p>
        </div>

        <!-- Demo notice -->
        <div class="mb-6 px-3 py-2.5 rounded-lg border border-dashed border-primary/20 dark:border-primary/30 bg-primary/5 text-[11px] leading-relaxed text-neutral-600 dark:text-neutral-300 text-center">
          <strong class="text-primary">Demo template.</strong> Wire up Auth.js, Clerk, Supabase, or your own backend before going live.
        </div>

        <!-- Social providers -->
        <div class="grid grid-cols-2 gap-3 mb-5">
          <button type="button" class="auth-social-btn">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <span>Google</span>
          </button>
          <button type="button" class="auth-social-btn">
            <GitFork class="w-4 h-4" />
            <span>GitHub</span>
          </button>
        </div>

        <!-- Divider -->
        <div class="relative flex items-center my-5">
          <div class="flex-1 border-t border-dashed border-neutral-200 dark:border-neutral-700"></div>
          <span class="px-3 text-[11px] font-medium uppercase tracking-[0.14em] text-neutral-400 dark:text-neutral-500">or with email</span>
          <div class="flex-1 border-t border-dashed border-neutral-200 dark:border-neutral-700"></div>
        </div>

        <!-- Form -->
        <form id="signup-form" class="space-y-4" novalidate>
          <div>
            <label for="name" class="block text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Full name</label>
            <div class="relative">
              <User class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400 dark:text-neutral-500 pointer-events-none" />
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder="Jane Doe"
                class="auth-input pl-10 pr-3.5"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Work email</label>
            <div class="relative">
              <Mail class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400 dark:text-neutral-500 pointer-events-none" />
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="you@company.com"
                class="auth-input pl-10 pr-3.5"
              />
            </div>
          </div>

          <div>
            <label for="password" class="block text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Password</label>
            <div class="relative">
              <Lock class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400 dark:text-neutral-500 pointer-events-none" />
              <input
                type="password"
                id="password"
                name="password"
                required
                minlength="8"
                autocomplete="new-password"
                placeholder="At least 8 characters"
                class="auth-input pl-10 pr-10"
              />
              <button type="button" id="toggle-pw" aria-label="Show password" class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded-md text-neutral-400 hover:text-primary dark:text-neutral-500 dark:hover:text-primary-light transition-colors">
                <Eye class="w-4 h-4 pw-eye" />
                <EyeOff class="w-4 h-4 pw-eye-off hidden" />
              </button>
            </div>

            <!-- Password strength hints -->
            <ul class="mt-2.5 space-y-1 text-[11px]" id="pw-hints">
              <li class="flex items-center gap-1.5 text-neutral-400 dark:text-neutral-500" data-rule="length">
                <Check class="w-3 h-3" /> At least 8 characters
              </li>
              <li class="flex items-center gap-1.5 text-neutral-400 dark:text-neutral-500" data-rule="number">
                <Check class="w-3 h-3" /> Contains a number
              </li>
              <li class="flex items-center gap-1.5 text-neutral-400 dark:text-neutral-500" data-rule="case">
                <Check class="w-3 h-3" /> Mix of upper and lower case
              </li>
            </ul>
          </div>

          <label class="flex items-start gap-2 cursor-pointer select-none pt-1">
            <input type="checkbox" id="terms" required class="auth-checkbox mt-0.5" />
            <span class="text-xs text-neutral-600 dark:text-neutral-400 leading-relaxed">
              I agree to the
              <a href="#" class="text-primary hover:text-primary-strong dark:text-primary-light transition-colors">Terms</a>
              and
              <a href="#" class="text-primary hover:text-primary-strong dark:text-primary-light transition-colors">Privacy Policy</a>
            </span>
          </label>

          <div class="signup-submit pt-1">
            <Button type="fill" url="javascript:void(0);" className="w-full justify-center">
              Create account <ArrowRight size={16} />
            </Button>
          </div>

          <div id="signup-success" class="hidden p-3 rounded-lg bg-green-50 dark:bg-green-900/20 border border-dashed border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-xs text-center">
            Account created — this is a template demo. No real account exists.
          </div>
        </form>
      </div>

      <!-- Switch -->
      <p class="text-center text-sm text-neutral-500 dark:text-neutral-400 mt-6">
        Already have an account?
        <a href="/signin" class="text-primary hover:text-primary-strong dark:text-primary-light font-medium transition-colors ml-1">Sign in</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .auth-input {
    width: 100%;
    padding-top: 0.625rem;
    padding-bottom: 0.625rem;
    border-radius: 0.625rem;
    border: 1px solid var(--color-neutral-200);
    background-color: var(--color-bg-primary);
    color: var(--color-neutral-800);
    font-size: 0.875rem;
    transition: border-color 200ms, box-shadow 200ms;
  }
  .auth-input::placeholder { color: var(--color-neutral-400); }
  .auth-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.12);
  }
  :global(.dark) .auth-input {
    background-color: var(--color-bg-secondary-dark);
    border-color: var(--color-neutral-700);
    color: var(--color-neutral-100);
  }
  :global(.dark) .auth-input::placeholder { color: var(--color-neutral-500); }

  .auth-social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.625rem;
    background-color: var(--color-bg-primary);
    border: 1px solid var(--color-neutral-200);
    color: var(--color-neutral-700);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .auth-social-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-1px);
  }
  :global(.dark) .auth-social-btn {
    background-color: var(--color-bg-secondary-dark);
    border-color: var(--color-neutral-700);
    color: var(--color-neutral-200);
  }
  :global(.dark) .auth-social-btn:hover {
    border-color: var(--color-primary-light);
    color: var(--color-primary-light);
  }

  .auth-checkbox {
    width: 1rem;
    height: 1rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-neutral-300);
    accent-color: var(--color-primary);
    cursor: pointer;
    flex-shrink: 0;
  }
  :global(.dark) .auth-checkbox {
    border-color: var(--color-neutral-600);
  }

  /* Password rule met state */
  #pw-hints li.met {
    color: var(--color-primary);
  }
  :global(.dark) #pw-hints li.met {
    color: var(--color-primary-light);
  }
</style>

<script>
  // Show/hide password
  const toggle = document.getElementById('toggle-pw');
  const pw = document.getElementById('password') as HTMLInputElement | null;
  toggle?.addEventListener('click', () => {
    if (!pw) return;
    const isPw = pw.type === 'password';
    pw.type = isPw ? 'text' : 'password';
    toggle.querySelector('.pw-eye')?.classList.toggle('hidden', isPw);
    toggle.querySelector('.pw-eye-off')?.classList.toggle('hidden', !isPw);
    toggle.setAttribute('aria-label', isPw ? 'Hide password' : 'Show password');
  });

  // Live password strength hints
  const hints = document.getElementById('pw-hints');
  pw?.addEventListener('input', () => {
    const v = pw.value;
    const rules = {
      length: v.length >= 8,
      number: /\d/.test(v),
      case: /[a-z]/.test(v) && /[A-Z]/.test(v),
    };
    hints?.querySelectorAll<HTMLLIElement>('[data-rule]').forEach((li) => {
      const r = li.dataset.rule as keyof typeof rules;
      li.classList.toggle('met', rules[r]);
    });
  });

  // Demo submit
  const form = document.getElementById('signup-form') as HTMLFormElement | null;
  const success = document.getElementById('signup-success');
  const submitBtn = document.querySelector('.signup-submit a') as HTMLAnchorElement | null;
  submitBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    if (!form?.checkValidity()) {
      form?.reportValidity();
      return;
    }
    success?.classList.remove('hidden');
    setTimeout(() => success?.classList.add('hidden'), 5000);
  });
</script>
